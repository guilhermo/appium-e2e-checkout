{
  "name": "mobile-appium",
  "type": "module",
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@wdio/allure-reporter": "^9.24.0",
    "@wdio/appium-service": "^9.24.0",
    "@wdio/cli": "^9.24.0",
    "@wdio/globals": "^9.23.0",
    "@wdio/local-runner": "^9.24.0",
    "@wdio/mocha-framework": "^9.24.0",
    "@wdio/spec-reporter": "^9.24.0",
    "@wdio/visual-service": "^9.1.6",
    "appium": "^3.2.0",
    "appium-uiautomator2-driver": "^2.2.0",
    "expect-webdriverio": "^5.6.4",
    "rimraf": "^6.1.3"
  },
  "scripts": {
    "wdio": "wdio run ./wdio.conf.ts",
    "clean": "rimraf allure-results allure-report",
    "test": "wdio run ./wdio.conf.ts",
    "report:generate": "allure generate allure-results --clean",
    "report:open": "allure open",
    "all-in-one": "npm run clean && npm run test && npm run report:generate && npm run report:open"
  }
}
